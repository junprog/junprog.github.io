---
// IsometricRoom.astro
import items from "../data/room-items.json";

const imageUrl =
  "https://lh3.googleusercontent.com/pw/AP1GczNI9tHd5zdEvDZe3WjMAK15jD7V2QG6TWup7VS_q-12IgqlZePDxP9WIv3V8gTkIapq1SuSUwucdoBkugURBU4sQU2S3iwm2aEWkw3THWhi4TxU1Tf8yko7nwhb_3hVQdkX7S5GXCqy6jCV3f_l69Kc9A=w1195-h896-s-no-gm?authuser=0";
const darkImageUrl =
  "https://lh3.googleusercontent.com/pw/AP1GczNFNJZu7unLZJkcs8nnHptSKz6eacVL-m3LVYpAAuH0VMz4CcKuqf09BY31-B80xsxteXl9SybB2kJ9NpJ6-JFUILkRilv8FOciKoRwsLvc0ELkL9aW8LWa6JymxQ23MCDhfv_VMai_0svTo2w2XtsTBw=w1195-h896-s-no-gm?authuser=0";
---

<div class="isometric-scroll-wrapper">
  <div class="isometric-container" id="iso-container">
    <img src={imageUrl} alt="My Setup Room" class="room-image light-img" />
    <img src={darkImageUrl} alt="My Setup Room" class="room-image dark-img" />

    <svg class="lines-overlay" width="100%" height="100%">
      <defs>
        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="3" result="coloredBlur"
          ></feGaussianBlur>
          <feMerge>
            <feMergeNode in="coloredBlur"></feMergeNode>
            <feMergeNode in="SourceGraphic"></feMergeNode>
          </feMerge>
        </filter>
      </defs>
      {
        items.map((item) => (
          <g>
            {item.link && (
              <circle
                cx={`${item.x1}%`}
                cy={`${item.y1}%`}
                r="6"
                class="origin-pulse"
              />
            )}
            <circle
              cx={`${item.x1}%`}
              cy={`${item.y1}%`}
              r="3"
              class={`origin-dot ${!item.link ? "no-link" : ""}`}
              filter={item.link ? "url(#glow)" : undefined}
            />
            <line
              id={`line-${item.id}`}
              x1={`${item.x1}%`}
              y1={`${item.y1}%`}
              x2={`${item.x2}%`}
              y2={`${item.y2}%`}
              class={`connection-line ${!item.link ? "no-link" : ""}`}
              filter={item.link ? "url(#glow)" : undefined}
            />
          </g>
        ))
      }
    </svg>

    <div class="labels-container">
      {
        items.map((item, index) => (
          <div
            class="label-pos-wrapper"
            style={`--x: ${item.x2}%; --y: ${item.y2}%;`}
          >
            <div
              class={`float-wrapper float-anim-${index % 3}`}
              style={`animation-delay: ${index * 0.7}s;`}
            >
              {item.link ? (
                <a href={item.link} class="label" id={`label-${item.id}`}>
                  <span class="label-dot" />
                  {item.title}
                </a>
              ) : (
                <div class="label no-link" id={`label-${item.id}`}>
                  <span class="label-dot no-link" />
                  {item.title}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .isometric-scroll-wrapper {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-left: 64px;
    padding-right: 64px;
  }

  .isometric-container {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
    border-radius: 16px;
    overflow: visible;
    container-type: inline-size;
  }

  .room-image {
    width: 100%;
    height: auto;
    opacity: 0.9;
    transition: opacity 0.5s;
    margin: 0 !important;
  }

  .light-img {
    display: block;
  }

  .dark-img {
    display: none;
  }

  :global(.dark) .light-img {
    display: none;
  }

  :global(.dark) .dark-img {
    display: block;
  }

  .isometric-container:hover .room-image {
    opacity: 1;
  }

  .lines-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 10;
    overflow: visible;
  }

  .origin-dot {
    fill: #00e5ff;
  }
  .origin-dot.no-link {
    fill: #9ca3af;
  }

  .origin-pulse {
    fill: none;
    stroke: #00e5ff;
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
    }
  }

  .connection-line {
    stroke: rgba(0, 229, 255, 0.6);
    stroke-width: 1.5;
    stroke-dasharray: 6 6;
    animation: dashAnim 30s linear infinite;
  }
  .connection-line.no-link {
    stroke: rgba(156, 163, 175, 0.6);
  }

  @keyframes dashAnim {
    to {
      stroke-dashoffset: -200;
    }
  }

  .labels-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 20;
  }

  .label-pos-wrapper {
    position: absolute;
    pointer-events: none;
    left: var(--x);
    top: var(--y);
  }

  .float-wrapper {
    pointer-events: none;
  }

  /* Different float animations for natural randomness */
  .float-anim-0 {
    animation: float1 6s ease-in-out infinite alternate;
  }
  .float-anim-1 {
    animation: float2 7.5s ease-in-out infinite alternate;
  }
  .float-anim-2 {
    animation: float3 8.5s ease-in-out infinite alternate;
  }

  .float-wrapper:hover {
    animation-play-state: paused;
  }

  .label {
    pointer-events: auto;
    position: absolute;
    transform: translate(-50%, -50%); /* Center on the origin */
    display: flex;
    align-items: center;
    gap: clamp(4px, 0.8cqi, 8px);
    padding: clamp(4px, 0.8cqi, 8px) clamp(8px, 1.6cqi, 16px);
    background: rgba(15, 17, 21, 0.7);
    color: #f0f0f0;
    text-decoration: none;
    font-weight: 600;
    font-size: clamp(0.55rem, 1.5cqi, 0.9rem);
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    border-radius: clamp(20px, 3cqi, 30px);
    border: 1px solid rgba(0, 229, 255, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    white-space: nowrap;
  }

  .label-dot {
    display: block;
    width: clamp(4px, 0.8cqi, 8px);
    height: clamp(4px, 0.8cqi, 8px);
    background: #00e5ff;
    border-radius: 50%;
    box-shadow: 0 0 10px #00e5ff;
    transition: transform 0.3s;
  }
  .label-dot.no-link {
    background: #9ca3af;
    box-shadow: none;
  }

  .label.no-link {
    border-color: rgba(156, 163, 175, 0.2);
    cursor: default;
  }

  .label:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background: rgba(20, 24, 32, 0.9);
    border-color: rgba(0, 229, 255, 0.8);
    box-shadow: 0 8px 25px rgba(0, 229, 255, 0.25);
    color: #fff;
    z-index: 30; /* Bring to front on hover */
  }

  .label.no-link:hover {
    transform: translate(-50%, -50%); /* no scale */
    border-color: rgba(156, 163, 175, 0.5);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3); /* original shadow */
  }

  .label:hover .label-dot {
    transform: scale(1.3);
  }

  .label.no-link:hover .label-dot {
    transform: none; /* no scale */
  }

  /* Floating Keyframes */
  @keyframes float1 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(4px, -8px);
    }
    66% {
      transform: translate(-5px, 6px);
    }
    100% {
      transform: translate(3px, 4px);
    }
  }

  @keyframes float2 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(-6px, -5px);
    }
    66% {
      transform: translate(7px, 5px);
    }
    100% {
      transform: translate(-4px, 6px);
    }
  }

  @keyframes float3 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(5px, 6px);
    }
    66% {
      transform: translate(-6px, -7px);
    }
    100% {
      transform: translate(4px, -5px);
    }
  }

  /* Mobile (501px to 768px) */
  @media (max-width: 768px) {
    .isometric-scroll-wrapper {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 0px 64px;
      box-sizing: border-box;
    }
    .isometric-scroll-wrapper::-webkit-scrollbar {
      display: none;
    }
    .isometric-container {
      min-width: 600px;
      scroll-snap-align: center;
    }
    .label-pos-wrapper {
      left: var(--x);
      top: var(--y);
    }
    /* Disable float animations on mobile to prevent layout calculations */
    .float-anim-0,
    .float-anim-1,
    .float-anim-2 {
      animation: none !important;
    }
  }

  /* Small Mobile (<= 500px) */
  @media (max-width: 500px) {
    .label-pos-wrapper {
      left: var(--x);
      top: var(--y);
    }
  }
</style>

<script>
  function initIsometricRoom() {
    const container = document.getElementById("iso-container");
    if (!container) return;

    // Center horizontal scroll on load
    const wrapper = document.querySelector(".isometric-scroll-wrapper");
    if (wrapper && wrapper.scrollWidth > wrapper.clientWidth) {
      wrapper.scrollLeft = (wrapper.scrollWidth - wrapper.clientWidth) / 2;
    }

    // Smooth scroll for record-rack-link label
    const rackLink = document.getElementById("label-record-rack-link");
    if (rackLink) {
      rackLink.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById("record-rack-root");
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    }

    // Skip the layout-thrashing frame loop on mobile viewports since animations are disabled
    const isMobile = window.matchMedia("(max-width: 768px)").matches;
    if (isMobile) {
      return () => {};
    }

    let isUpdating = false;

    function updateLines() {
      if (!isUpdating || !container) return;

      const containerRect = container.getBoundingClientRect();
      const labels = document.querySelectorAll(".label");

      // Read phase: calculate all new positions
      const updates = Array.from(labels)
        .map((label) => {
          const id = label.id.replace("label-", "");
          const line = document.getElementById(`line-${id}`);
          if (!line) return null;

          const rect = label.getBoundingClientRect();

          // Calculate center relative to the container
          const x2 =
            ((rect.left + rect.width / 2 - containerRect.left) /
              containerRect.width) *
            100;
          const y2 =
            ((rect.top + rect.height / 2 - containerRect.top) /
              containerRect.height) *
            100;

          return { line, x2, y2 };
        })
        .filter(
          (item): item is { line: HTMLElement; x2: number; y2: number } =>
            item !== null,
        );

      // Write phase: update DOM
      updates.forEach(({ line, x2, y2 }) => {
        line.setAttribute("x2", `${x2}%`);
        line.setAttribute("y2", `${y2}%`);
      });

      requestAnimationFrame(updateLines);
    }

    // Use IntersectionObserver to start/stop loop based on visibility
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!isUpdating) {
              isUpdating = true;
              updateLines();
            }
          } else {
            isUpdating = false;
          }
        });
      },
      { threshold: 0.05 },
    );

    observer.observe(container);

    // Clean up if component is unmounted (useful for view transitions)
    return () => {
      isUpdating = false;
      observer.disconnect();
    };
  }

  // Handle standard load and Astro view transitions
  let cleanup: (() => void) | undefined;
  document.addEventListener("astro:page-load", () => {
    if (cleanup) cleanup();
    cleanup = initIsometricRoom();
  });

  // Fallback for first load if astro:page-load hasn't fired
  if (!cleanup) {
    cleanup = initIsometricRoom();
  }
</script>
