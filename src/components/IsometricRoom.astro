const imageUrl =
  "https://lh3.googleusercontent.com/pw/AP1GczNI9tHd5zdEvDZe3WjMAK15jD7V2QG6TWup7VS_q-12IgqlZePDxP9WIv3V8gTkIapq1SuSUwucdoBkugURBU4sQU2S3iwm2aEWkw3THWhi4TxU1Tf8yko7nwhb_3hVQdkX7S5GXCqy6jCV3f_l69Kc9A=w1195-h896-s-no-gm?authuser=0";
const darkImageUrl =
  "https://lh3.googleusercontent.com/pw/AP1GczNFNJZu7unLZJkcs8nnHptSKz6eacVL-m3LVYpAAuH0VMz4CcKuqf09BY31-B80xsxteXl9SybB2kJ9NpJ6-JFUILkRilv8FOciKoRwsLvc0ELkL9aW8LWa6JymxQ23MCDhfv_VMai_0svTo2w2XtsTBw=w1195-h896-s-no-gm?authuser=0";
---

<div class="isometric-container" id="iso-container">
  <img src={imageUrl} alt="My Setup Room" class="room-image light-img" />
  <img src={darkImageUrl} alt="My Setup Room" class="room-image dark-img" />

  <svg class="lines-overlay" width="100%" height="100%">
    <defs>
      <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="coloredBlur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="coloredBlur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
    </defs>
    {
      items.map((item) => (
        <g>
          {item.link && (
            <circle
              cx={`${item.x1}%`}
              cy={`${item.y1}%`}
              r="6"
              class="origin-pulse"
            />
          )}
          <circle
            cx={`${item.x1}%`}
            cy={`${item.y1}%`}
            r="3"
            class={`origin-dot ${!item.link ? "no-link" : ""}`}
            filter={item.link ? "url(#glow)" : undefined}
          />
          <line
            id={`line-${item.id}`}
            x1={`${item.x1}%`}
            y1={`${item.y1}%`}
            x2={`${item.x2}%`}
            y2={`${item.y2}%`}
            class={`connection-line ${!item.link ? "no-link" : ""}`}
            filter={item.link ? "url(#glow)" : undefined}
          />
        </g>
      ))
    }
  </svg>

  <div class="labels-container">
    {
      items.map((item, index) => (
        <div
          class="label-pos-wrapper"
          style={`--x: ${item.x2}%; --y: ${item.y2}%;`}
        >
          <div
            class={`float-wrapper float-anim-${index % 3}`}
            style={`animation-delay: ${index * 0.7}s;`}
          >
            {item.link ? (
              <a href={item.link} class="label" id={`label-${item.id}`}>
                <span class="label-dot" />
                {item.title}
              </a>
            ) : (
              <div class="label no-link" id={`label-${item.id}`}>
                <span class="label-dot no-link" />
                {item.title}
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .isometric-container {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
    border-radius: 16px;
    overflow: visible;
  }

  .room-image {
    width: 100%;
    height: auto;
    opacity: 0.9;
    transition: opacity 0.5s;
  }

  .light-img {
    display: block;
  }

  .dark-img {
    display: none;
  }

  :global(.dark) .light-img {
    display: none;
  }

  :global(.dark) .dark-img {
    display: block;
  }

  .isometric-container:hover .room-image {
    opacity: 1;
  }

  .lines-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 10;
    overflow: visible;
  }

  .origin-dot {
    fill: #00e5ff;
  }
  .origin-dot.no-link {
    fill: #9ca3af;
  }

  .origin-pulse {
    fill: none;
    stroke: #00e5ff;
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
    }
  }

  .connection-line {
    stroke: rgba(0, 229, 255, 0.6);
    stroke-width: 1.5;
    stroke-dasharray: 6 6;
    animation: dashAnim 30s linear infinite;
  }
  .connection-line.no-link {
    stroke: rgba(156, 163, 175, 0.6);
  }

  @keyframes dashAnim {
    to {
      stroke-dashoffset: -200;
    }
  }

  .labels-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 20;
  }

  .label-pos-wrapper {
    position: absolute;
    pointer-events: none;
    /* Smoothly clamp to viewport edges to prevent horizontal overflow without sudden jumps */
    left: clamp(calc(50% - 50vw + 160px), var(--x), calc(50% + 50vw - 160px));
    top: var(--y);
  }

  .float-wrapper {
    pointer-events: none;
  }

  /* Different float animations for natural randomness */
  .float-anim-0 {
    animation: float1 6s ease-in-out infinite alternate;
  }
  .float-anim-1 {
    animation: float2 7.5s ease-in-out infinite alternate;
  }
  .float-anim-2 {
    animation: float3 8.5s ease-in-out infinite alternate;
  }

  .float-wrapper:hover {
    animation-play-state: paused;
  }

  .label {
    pointer-events: auto;
    position: absolute;
    transform: translate(-50%, -50%); /* Center on the origin */
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(15, 17, 21, 0.7);
    color: #f0f0f0;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    border-radius: 30px;
    border: 1px solid rgba(0, 229, 255, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    white-space: nowrap;
  }

  .label-dot {
    display: block;
    width: 8px;
    height: 8px;
    background: #00e5ff;
    border-radius: 50%;
    box-shadow: 0 0 10px #00e5ff;
    transition: transform 0.3s;
  }
  .label-dot.no-link {
    background: #9ca3af;
    box-shadow: none;
  }

  .label.no-link {
    border-color: rgba(156, 163, 175, 0.2);
    cursor: default;
  }

  .label:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background: rgba(20, 24, 32, 0.9);
    border-color: rgba(0, 229, 255, 0.8);
    box-shadow: 0 8px 25px rgba(0, 229, 255, 0.25);
    color: #fff;
    z-index: 30; /* Bring to front on hover */
  }

  .label.no-link:hover {
    transform: translate(-50%, -50%); /* no scale */
    border-color: rgba(156, 163, 175, 0.5);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3); /* original shadow */
  }

  .label:hover .label-dot {
    transform: scale(1.3);
  }

  .label.no-link:hover .label-dot {
    transform: none; /* no scale */
  }

  /* Floating Keyframes */
  @keyframes float1 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(4px, -8px);
    }
    66% {
      transform: translate(-5px, 6px);
    }
    100% {
      transform: translate(3px, 4px);
    }
  }

  @keyframes float2 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(-6px, -5px);
    }
    66% {
      transform: translate(7px, 5px);
    }
    100% {
      transform: translate(-4px, 6px);
    }
  }

  @keyframes float3 {
    0% {
      transform: translate(0, 0);
    }
    33% {
      transform: translate(5px, 6px);
    }
    66% {
      transform: translate(-6px, -7px);
    }
    100% {
      transform: translate(4px, -5px);
    }
  }

  /* Mobile (501px to 768px) */
  @media (max-width: 768px) {
    .label-pos-wrapper {
      left: clamp(90px, var(--x), calc(100% - 90px));
      top: var(--y);
    }
    .label {
      font-size: 0.65rem;
      padding: 5px 10px;
      gap: 5px;
    }
    .label-dot {
      width: 5px;
      height: 5px;
    }
  }

  /* Small Mobile (<= 500px) */
  @media (max-width: 500px) {
    .label-pos-wrapper {
      left: clamp(75px, var(--x), calc(100% - 75px));
      top: var(--y);
    }
    .label {
      font-size: 0.55rem;
      padding: 4px 8px;
      gap: 4px;
      border-radius: 20px;
    }
    .label-dot {
      width: 4px;
      height: 4px;
    }
  }
</style>

<script>
  function initIsometricRoom() {
    const container = document.getElementById("iso-container");
    if (!container) return;

    let isUpdating = true;

    function updateLines() {
      if (!isUpdating) return;

      const containerRect = container.getBoundingClientRect();
      const labels = document.querySelectorAll(".label");

      // Read phase: calculate all new positions
      const updates = Array.from(labels)
        .map((label) => {
          const id = label.id.replace("label-", "");
          const line = document.getElementById(`line-${id}`);
          if (!line) return null;

          const rect = label.getBoundingClientRect();

          // Calculate center relative to the container
          const x2 =
            ((rect.left + rect.width / 2 - containerRect.left) /
              containerRect.width) *
            100;
          const y2 =
            ((rect.top + rect.height / 2 - containerRect.top) /
              containerRect.height) *
            100;

          return { line, x2, y2 };
        })
        .filter(Boolean);

      // Write phase: update DOM
      updates.forEach(({ line, x2, y2 }) => {
        line.setAttribute("x2", `${x2}%`);
        line.setAttribute("y2", `${y2}%`);
      });

      requestAnimationFrame(updateLines);
    }

    // Start animation loop
    updateLines();

    // Clean up if component is unmounted (useful for view transitions)
    return () => {
      isUpdating = false;
    };
  }

  // Handle standard load and Astro view transitions
  let cleanup;
  document.addEventListener("astro:page-load", () => {
    if (cleanup) cleanup();
    cleanup = initIsometricRoom();
  });

  // Fallback for first load if astro:page-load hasn't fired
  if (!cleanup) {
    cleanup = initIsometricRoom();
  }
</script>
