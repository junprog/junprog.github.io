---
import { getPostUrl, getPostDate, CATEGORY_MAP } from "../utils/post";
import { marked } from "marked";

export interface Props {
  post: any;
}

const { post } = Astro.props;

const displayDate = getPostDate(post).toISOString().split("T")[0];
const rawCategory = post.data.category || "ブログ";
const categoryUrl = CATEGORY_MAP[rawCategory] || "blog";
const postUrl = getPostUrl(post);

// Parse excerpt: strip frontmatter then split by <!--more-->
const bodyWithoutFrontmatter = post.body.replace(/^---\n[\s\S]*?\n---\n/, "");
const excerptRaw = bodyWithoutFrontmatter.split(
  /<!--more-->|\{\/\*\s*more\s*\*\/\}/,
)[0];
const excerpt = marked.parse(excerptRaw);

// Extract first non-SVG image URL
let thumbnailUrl = null;
const imgRegex = /!\[.*?\]\(([^)\s]+).*?\)|<img[^>]+src=["']([^"']+)["']/g;
let match;
while ((match = imgRegex.exec(post.body)) !== null) {
  const url = match[1] || match[2];
  if (url && !/\.svg(\?.*)?$/i.test(url)) {
    thumbnailUrl = url;
    break;
  }
}
---

<article
  class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 md:p-8 my-6 transition-colors duration-300 flex flex-col md:flex-row gap-8 items-start"
>
  <div class="flex-1 min-w-0 w-full">
    <div class="border-b border-gray-200 dark:border-gray-700 pb-4 mb-6">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        <a href={postUrl} class="hover:text-blue-500 transition-colors"
          >{post.data.title}</a
        >
      </h1>
      <div
        class="flex flex-wrap gap-4 text-sm text-gray-500 dark:text-gray-400"
      >
        <span class="flex items-center gap-1" aria-hidden="true">
          <i class="fas fa-calendar-alt"></i>
          <span class="font-medium">{displayDate}</span>
        </span>

        <span class="flex items-center gap-1" aria-hidden="true">
          <i class="fa-solid fa-folder-tree"></i>
          <a
            href={`/posts/${categoryUrl}`}
            class="hover:text-blue-500 transition-colors">{rawCategory}</a
          >
        </span>

        <span class="flex items-center gap-1 flex-wrap" aria-hidden="true">
          <i class="fas fa-tag"></i>
          {
            (post.data.tags || []).map((tag: string) => (
              <a
                href={`/tags#${tag}`}
                class="border border-gray-300 dark:border-gray-600 rounded px-2 py-0.5 hover:border-blue-500 hover:text-blue-500 transition-colors"
              >
                {tag}
              </a>
            ))
          }
        </span>
      </div>
    </div>

    <div
      class="prose prose-slate dark:prose-invert prose-pre:bg-gray-100 dark:prose-pre:bg-gray-900 prose-pre:text-gray-900 dark:prose-pre:text-gray-100 max-w-none"
      set:html={excerpt}
    />

    <a
      href={postUrl}
      class="inline-block mt-6 text-blue-500 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-colors"
      >Read More</a
    >
  </div>

  {
    thumbnailUrl && (
      <div class="w-full md:w-1/3 shrink-0 md:mt-0 flex justify-center">
        <a
          href={postUrl}
          class="block w-full overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 group"
        >
          <img
            src={thumbnailUrl}
            alt="Thumbnail"
            class="w-full h-auto object-cover object-center max-h-48 md:max-h-full"
          />
        </a>
      </div>
    )
  }
</article>
