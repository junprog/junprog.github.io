---
const siteName = "junprog";
const siteDescription = "日常、研究、勉強、趣味、等々。";
const siteAvatar = "https://avatars.githubusercontent.com/u/39183997?v=4";
---

<div
	id="site-header"
	class="group/header sticky top-0 z-50 bg-white/95 dark:bg-gray-800/95 backdrop-blur-md border-b border-gray-200 dark:border-gray-700 mb-6 transition-all duration-300 relative"
	style="overflow-anchor: none;"
>
	<div class="max-w-4xl mx-auto px-4">
		<header
			id="header-content"
			class="py-6 group-data-[terminal-hidden=true]/header:py-3 flex flex-row items-center justify-between transition-all duration-300"
		>
			<div class="flex items-center">
				<a
					href="/"
					class="w-[50px] h-[50px] sm:w-[70px] sm:h-[70px] group-data-[terminal-hidden=true]/header:w-[32px] group-data-[terminal-hidden=true]/header:h-[32px] group-data-[terminal-hidden=true]/header:sm:w-[40px] group-data-[terminal-hidden=true]/header:sm:h-[40px] mr-3 sm:mr-4 flex-shrink-0 block transition-all duration-300"
					id="header-avatar"
				>
					<img
						src={siteAvatar}
						alt="avatar"
						class="rounded-xl object-cover w-full h-full"
					/>
				</a>

				<div class="flex flex-col justify-center">
					<h1
						class="text-xl sm:text-[28px] group-data-[terminal-hidden=true]/header:sm:text-xl font-light tracking-wide m-0 leading-tight transition-all duration-300"
						id="header-title"
					>
						<a
							href="/"
							class="text-gray-900 dark:text-gray-100 hover:text-blue-500 transition-colors"
							>{siteName}</a
						>
					</h1>
					<p
						class="text-gray-500 dark:text-gray-400 m-0 text-sm sm:text-base mt-1 group-data-[terminal-hidden=true]/header:mt-0 max-h-10 group-data-[terminal-hidden=true]/header:max-h-0 opacity-100 group-data-[terminal-hidden=true]/header:opacity-0 transition-all duration-300 overflow-hidden hidden sm:block"
						id="header-desc"
					>
						{siteDescription}
					</p>
				</div>
			</div>

			<nav
				class="flex flex-row justify-end items-center gap-x-3 sm:gap-x-6 text-base sm:text-lg font-light tracking-wide transition-all duration-300"
				id="header-nav"
			>
				<a
					href="/"
					class="text-gray-800 dark:text-gray-200 hover:text-blue-500 transition-colors"
					>Home</a
				>
				<a
					href="/posts"
					class="text-gray-800 dark:text-gray-200 hover:text-blue-500 transition-colors"
					>Posts</a
				>
				<button
					id="theme-toggle"
					class="text-gray-800 dark:text-gray-200 hover:text-blue-500 transition-colors focus:outline-none ml-1 sm:ml-2 cursor-pointer"
					aria-label="Toggle dark mode"
				>
					<i class="fas fa-adjust"></i>
				</button>
			</nav>
		</header>
		<!-- 疑似ターミナルUI -->
		<div
			id="terminal-container"
			class="transition-all duration-500 ease-in-out overflow-hidden transform origin-top opacity-100 group-data-[terminal-hidden=true]/header:opacity-0 max-h-[500px] group-data-[terminal-hidden=true]/header:max-h-0 scale-y-100 group-data-[terminal-hidden=true]/header:scale-y-0"
		>
			<slot name="terminal" />
		</div>
	</div>

	<button
		id="terminal-toggle-btn"
		class="absolute -bottom-4 left-1/2 transform -translate-x-1/2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-500 hover:text-blue-500 rounded-full w-8 h-8 flex items-center justify-center cursor-pointer transition-all duration-300 z-50 focus:outline-none"
		aria-label="Toggle Terminal"
	>
		<div
			id="terminal-toggle-icon"
			class="transition-transform duration-300 transform group-data-[terminal-hidden=true]/header:rotate-180 flex items-center justify-center w-full h-full"
		>
			<i class="fas fa-chevron-up text-sm"></i>
		</div>
	</button>
</div>

<script is:inline>
	// Dark Mode Toggle
	const toggleBtn = document.getElementById("theme-toggle");
	if (toggleBtn) {
		toggleBtn.addEventListener("click", () => {
			const toggleTheme = () => {
				const isDark =
					document.documentElement.classList.contains("dark");
				if (isDark) {
					document.documentElement.classList.remove("dark");
					document.documentElement.setAttribute(
						"data-theme",
						"light",
					);
					localStorage.setItem("theme", "light");
				} else {
					document.documentElement.classList.add("dark");
					document.documentElement.setAttribute("data-theme", "dark");
					localStorage.setItem("theme", "dark");
				}
			};

			if (!document.startViewTransition) {
				toggleTheme();
			} else {
				// 既存のCSSトランジションと干渉しないよう一時的にbodyのクラスを制御
				document.body.classList.remove(
					"transition-colors",
					"duration-300",
				);
				document.startViewTransition(() => {
					toggleTheme();
				});
				// トランジションが完了したら元に戻す
				setTimeout(() => {
					document.body.classList.add(
						"transition-colors",
						"duration-300",
					);
				}, 500);
			}
		});
	}

	// Scroll and Hover Logic
	const siteHeader = document.getElementById("site-header");
	const headerContent = document.getElementById("header-content");
	const terminalContainer = document.getElementById("terminal-container");
	const headerAvatar = document.getElementById("header-avatar");
	const headerTitle = document.getElementById("header-title");
	const headerDesc = document.getElementById("header-desc");
	const terminalToggleBtn = document.getElementById("terminal-toggle-btn");

	let lastScrollY = window.scrollY;

	let isTerminalVisible = true;
	let ignoreScrollEvents = false;
	let scrollTimeout = null;

	function setIgnoreScroll() {
		ignoreScrollEvents = true;
		if (scrollTimeout) clearTimeout(scrollTimeout);
		scrollTimeout = setTimeout(() => {
			ignoreScrollEvents = false;
			lastScrollY = window.scrollY; // アニメーション終了後の位置を基準にする
		}, 550); // 500msのトランジション + 少し余裕を持たせる
	}
	window.setIgnoreHeaderScroll = setIgnoreScroll;

	function hideTerminal() {
		if (!isTerminalVisible) return;
		isTerminalVisible = false;
		sessionStorage.setItem("terminal_visibility", "hidden");
		setIgnoreScroll();
		siteHeader.dataset.terminalHidden = "true";
	}

	function showTerminal() {
		if (isTerminalVisible) return;
		isTerminalVisible = true;
		sessionStorage.setItem("terminal_visibility", "visible");
		setIgnoreScroll();
		delete siteHeader.dataset.terminalHidden;
	}

	// ページ読み込み時に状態を復元（アニメーションなしで即時反映）
	const savedState = sessionStorage.getItem("terminal_visibility");
	if (savedState === "hidden") {
		const elementsWithTransition = [
			siteHeader,
			headerContent,
			headerAvatar,
			headerTitle,
			headerDesc,
			terminalContainer,
			document.getElementById("terminal-toggle-icon"),
		];

		elementsWithTransition.forEach((el) => {
			if (el) el.style.transition = "none";
		});

		isTerminalVisible = true; // hideTerminal()を確実に実行させるため
		hideTerminal();

		void document.body.offsetHeight; // 強制リフロー

		elementsWithTransition.forEach((el) => {
			if (el) el.style.transition = "";
		});
	} else {
		sessionStorage.setItem("terminal_visibility", "visible");
	}

	if (terminalToggleBtn) {
		terminalToggleBtn.addEventListener("click", () => {
			if (!isTerminalVisible) {
				showTerminal();
			} else {
				hideTerminal();
			}
		});
	}
	// ページ最上部にいるときの上スクロール検知
	// （位置が変わらないためscrollイベントが発火しないブラウザ環境への対策）
	window.addEventListener(
		"wheel",
		(e) => {
			if (window.scrollY <= 0 && e.deltaY < 0) {
				if (!isTerminalVisible) {
					showTerminal();
				}
			}
		},
		{ passive: true },
	);

	let touchStartY = 0;
	window.addEventListener(
		"touchstart",
		(e) => {
			touchStartY = e.touches[0].clientY;
		},
		{ passive: true },
	);

	window.addEventListener(
		"touchmove",
		(e) => {
			if (window.scrollY <= 0) {
				const touchY = e.touches[0].clientY;
				// スワイプダウン（画面上では上方向へのスクロール）
				if (touchY > touchStartY + 10) {
					if (!isTerminalVisible) {
						showTerminal();
					}
				}
			}
		},
		{ passive: true },
	);
	window.addEventListener(
		"scroll",
		() => {
			if (ignoreScrollEvents) return;

			const currentScrollY = window.scrollY;

			// バウンススクロール（iOSなど）の対策やページ最上部での表示
			if (currentScrollY <= 0) {
				showTerminal();
				lastScrollY = currentScrollY;
				return;
			}

			if (currentScrollY > lastScrollY) {
				// スクロールが下がった場合 (少しでも)
				hideTerminal();
			}

			lastScrollY = currentScrollY;
		},
		{ passive: true },
	);
</script>
