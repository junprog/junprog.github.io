---
import Layout from "../layouts/Layout.astro";
import Terminal from "../components/Terminal.astro";
import GadgetCard from "../components/GadgetCard.astro";
import IsometricRoom from "../components/IsometricRoom.astro";
import RecordRack from "../components/RecordRack.astro";

const skills = [
  {
    title: "言語・フレームワーク",
    desc: "Python / PyTorch / Tensorflow など",
    iconClasses:
      "bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400",
    iconPath: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  },
  {
    title: "分野・専門",
    desc: "コンピュータビジョン / 機械学習 など",
    iconClasses:
      "bg-pink-50 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400",
    iconPath:
      "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
];

const hobbies = [
  {
    label: "🦆 野鳥撮影",
    classes:
      "bg-blue-100/50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800",
  },
  {
    label: "⛰️ 登山",
    classes:
      "bg-green-100/50 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800",
  },
  {
    label: "🏰 ディズニー",
    classes:
      "bg-purple-100/50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800",
  },
  {
    label: "🎷 ジャズ",
    classes:
      "bg-yellow-100/50 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-800",
  },
  {
    label: "🏃 ランニング",
    classes:
      "bg-red-100/50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border-red-200 dark:border-red-800",
  },
];
---

<Layout title="about me">
  <Terminal slot="terminal" />

  <div class="max-w-4xl mx-auto pb-12">
    <!-- Header Section -->
    <div class="prose prose-slate dark:prose-invert max-w-none mb-10">
      <h1
        class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6 tracking-tight flex items-center gap-3"
      >
        <svg
          class="w-8 h-8 text-gray-700 dark:text-gray-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
          ></path>
        </svg>
        About me
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        こんにちは、<code>junprog</code>です。<br /><br />
        本ブログでは、日常であったこと、やってみたいことなど、思ったことをゆるく発信していきます。
      </p>
    </div>

    <div class="space-y-16">
      <!-- 🛠️ スキル -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          スキル
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            skills.map((skill) => (
              <div class="flex items-start gap-4 p-5 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-xl">
                <div class={`p-3 rounded-lg ${skill.iconClasses}`}>
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d={skill.iconPath}
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-gray-100">
                    {skill.title}
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                    {skill.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 🔭 最近ハマっていること (Icon Cards / Chips) -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
            ></path>
          </svg>
          趣味
        </h2>
        <div
          class="bg-gray-50 dark:bg-gray-800/50 rounded-2xl p-6 border border-gray-200 dark:border-gray-700"
        >
          <p class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
            多趣味な性格です。小さい頃からサイクリングや絵描き、楽器など、色々触れては飽きを繰り返しています。<br
            />
            現在は、以下の趣味に夢中になってます。
          </p>
          <div class="flex flex-wrap gap-3">
            {
              hobbies.map((hobby) => (
                <div
                  class={`flex items-center gap-2 px-4 py-2 rounded-full font-medium text-sm border ${hobby.classes}`}
                >
                  {hobby.label}
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- 📷 マイルーム (Image Cards) -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            ></path>
          </svg>
          マイルーム
        </h2>

        <IsometricRoom />

        <RecordRack />
      </section>

      <!-- サイトマップ -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
            ></path>
          </svg>
          サイトマップ
        </h2>
        <div
          class="bg-gray-800 rounded-xl p-6 overflow-hidden shadow-inner border border-gray-800"
        >
          <pre
            class="text-green-400 font-mono text-sm m-0 bg-transparent p-0 leading-relaxed"><code> ~/
  ├ posts/
  │ ├ blog/
  │ ├ playground/
  │ └ survey/
  ├ tags
  └ categories</code></pre>
        </div>
      </section>
    </div>
  </div>
</Layout>
