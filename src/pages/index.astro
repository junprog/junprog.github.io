---
import Layout from "../layouts/Layout.astro";
import Terminal from "../components/Terminal.astro";
import GadgetCard from "../components/GadgetCard.astro";
import IsometricRoom from "../components/IsometricRoom.astro";
---

<Layout title="about me">
  <Terminal slot="terminal" />

  <div class="max-w-4xl mx-auto pb-12">
    <!-- Header Section -->
    <div class="prose prose-slate dark:prose-invert max-w-none mb-10">
      <h1
        class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6 tracking-tight"
      >
        About me
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        こんにちは、<code>junprog</code>です。<br /><br />
        本ブログでは、日常であったこと、やってみたいことなど、思ったことをゆるく発信していきます。
      </p>
    </div>

    <div class="space-y-16">
      <!-- 🛠️ スキル -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          スキル
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div
            class="flex items-start gap-4 p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl"
          >
            <div
              class="p-3 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-lg"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 dark:text-gray-100">
                言語・フレームワーク
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                Python / PyTorch / Tensorflow など
              </p>
            </div>
          </div>
          <div
            class="flex items-start gap-4 p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl"
          >
            <div
              class="p-3 bg-pink-50 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400 rounded-lg"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 dark:text-gray-100">
                分野・専門
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                コンピュータビジョン / 機械学習 など
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- 🔭 最近ハマっていること (Icon Cards / Chips) -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
            ></path>
          </svg>
          趣味
        </h2>
        <div
          class="bg-gray-50 dark:bg-gray-800/50 rounded-2xl p-6 border border-gray-200 dark:border-gray-700"
        >
          <p class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
            多趣味な性格です。小さい頃からサイクリングや絵描き、楽器など、色々触れては飽きを繰り返しています。<br
            />
            現在は、以下の趣味に夢中になってます。
          </p>
          <div class="flex flex-wrap gap-3">
            <div
              class="flex items-center gap-2 px-4 py-2 bg-blue-100/50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full font-medium text-sm border border-blue-200 dark:border-blue-800"
            >
              🦆 野鳥撮影
            </div>
            <div
              class="flex items-center gap-2 px-4 py-2 bg-green-100/50 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full font-medium text-sm border border-green-200 dark:border-green-800"
            >
              ⛰️ 登山
            </div>
            <div
              class="flex items-center gap-2 px-4 py-2 bg-purple-100/50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full font-medium text-sm border border-purple-200 dark:border-purple-800"
            >
              🏰 ディズニー
            </div>
            <div
              class="flex items-center gap-2 px-4 py-2 bg-yellow-100/50 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 rounded-full font-medium text-sm border border-yellow-200 dark:border-yellow-800"
            >
              🎷 ジャズ
            </div>
            <div
              class="flex items-center gap-2 px-4 py-2 bg-red-100/50 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-full font-medium text-sm border border-red-200 dark:border-red-800"
            >
              🏃 ランニング
            </div>
          </div>
        </div>
      </section>

      <!-- 📷 愛用機材・ガジェット (Image Cards) -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          愛用ガジェット
        </h2>

        <IsometricRoom />
      </section>

      <!-- サイトマップ -->
      <section>
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2"
        >
          <svg
            class="w-6 h-6 text-gray-700 dark:text-gray-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
            ></path>
          </svg>
          サイトマップ
        </h2>
        <div
          class="bg-gray-900 rounded-xl p-6 overflow-hidden shadow-inner border border-gray-800"
        >
          <pre
            class="text-green-400 font-mono text-sm m-0 bg-transparent p-0 leading-relaxed"><code> ~/
  ├ posts/
  │ ├ blog/
  │ ├ playground/
  │ └ survey/
  ├ tags
  └ categories</code></pre>
        </div>
      </section>
    </div>
  </div>
</Layout>
