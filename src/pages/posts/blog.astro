---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Terminal from '../../components/Terminal.astro';
import { sortPostsDesc, getPostUrl, getPostDate } from '../../utils/post';
import PostCard from '../../components/PostCard.astro';

const posts = await getCollection('posts');
const blogPosts = sortPostsDesc(posts.filter(post => post.data.category === "ブログ"));
console.log("DEBUG POST BODY:", blogPosts[0]?.body?.substring(0, 200));
---

<Layout title="Blog">
  <Terminal slot="terminal" />

  <blockquote class="text-center my-8">
    <h1 class="text-4xl text-gray-400 dark:text-gray-500">
      <i class="fa-solid fa-pencil"></i>
    </h1>
  </blockquote>

  <div class="posts">
    {blogPosts.map((post: any) => (
      <PostCard post={post} />
    ))}
  </div>

  <div class="text-center mt-8 mb-4">
    <a href="/categories" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">カテゴリ一覧</a>
    <a href="/tags" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">タグ一覧</a>
  </div>
</Layout>
