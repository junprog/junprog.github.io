---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Terminal from '../../components/Terminal.astro';
import PostCard from '../../components/PostCard.astro';
import { sortPostsDesc } from '../../utils/post';

export async function getStaticPaths({ paginate }: any) {
  const posts = await getCollection('posts');
  const sorted = sortPostsDesc(posts);
  return paginate(sorted, { pageSize: 5 });
}

const { page } = Astro.props;
---

<Layout title="all posts">
  <Terminal slot="terminal" />

  <blockquote class="text-center my-8">
    <h1 class="text-4xl text-gray-400 dark:text-gray-500">
      <i class="fa-solid fa-book"></i>
    </h1>
  </blockquote>

  <div class="posts">
    {page.data.map((post: any) => (
      <PostCard post={post} />
    ))}
  </div>

  <div class="text-center mt-8 mb-4">
    {page.lastPage > 1 && (
      <div class="flex justify-center items-center flex-wrap gap-2 my-8">
        {page.url.prev ? (
          <a href={page.url.prev} class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            <i class="fa-solid fa-chevron-up fa-rotate-270 fa-sm"></i> 前へ
          </a>
        ) : (
          <span class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-gray-50 dark:bg-gray-800 text-gray-400 dark:text-gray-500 cursor-not-allowed">
            <i class="fa-solid fa-chevron-up fa-rotate-270 fa-sm"></i> 前へ
          </span>
        )}

        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(pageNum => {
          const url = pageNum === 1 ? '/posts' : `/posts/${pageNum}`;
          const isCurrent = pageNum === page.currentPage;
          return isCurrent ? (
            <em class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 font-bold not-italic">{pageNum}</em>
          ) : (
            <a href={url} class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">{pageNum}</a>
          );
        })}

        {page.url.next ? (
          <a href={page.url.next} class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            次へ <i class="fa-solid fa-chevron-up fa-rotate-90 fa-sm"></i>
          </a>
        ) : (
          <span class="border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 bg-gray-50 dark:bg-gray-800 text-gray-400 dark:text-gray-500 cursor-not-allowed">
            次へ <i class="fa-solid fa-chevron-up fa-rotate-90 fa-sm"></i>
          </span>
        )}
      </div>
    )}

    <a href="/categories" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">カテゴリ一覧</a>
    <a href="/tags" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">タグ一覧</a>
  </div>
</Layout>
