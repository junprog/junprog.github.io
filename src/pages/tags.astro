---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import { sortPostsDesc, getPostUrl } from '../utils/post';

const posts = await getCollection('posts');

const tagMap: Record<string, any[]> = {};
posts.forEach(post => {
  const tags = post.data.tags || [];
  tags.forEach(tag => {
    if (!tagMap[tag]) {
      tagMap[tag] = [];
    }
    tagMap[tag].push(post);
  });
});

const sortedTags = Object.keys(tagMap).sort();
---

<Layout title="タグ">
  <Terminal slot="terminal" />

  {sortedTags.map(tag => {
    const tagPosts = sortPostsDesc(tagMap[tag]);

    return (
      <article>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 md:p-8 my-6 shadow-sm prose prose-slate dark:prose-invert max-w-none transition-colors duration-300">
          <h2 id={tag} class="tag">{tag}</h2>
          <ul>
            {tagPosts.map(post => (
              <li>
                <a href={getPostUrl(post)}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </article>
    );
  })}

  <div class="text-center mt-8 mb-4">
    <a href="/categories" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">カテゴリ一覧</a>
    <a href="/tags" class="mx-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors font-medium">タグ一覧</a>
  </div>
</Layout>
